<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anjali Portfolio</title>

    <link rel="stylesheet" href="portfolio.css">

    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

    <header>
        <nav>
            <h2 class="logo">Anjali</h2>

            <ul>
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#skills">Skills</a></li>
                <li><a href="#projects">Projects</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>

            <a href="#contact" class="btn">Hire Me</a>
        </nav>
    </header>

    <section class="hero" id="home">
        <div class="hero-content">
            <h1>Hi, I'm <span>Anjali Patial</span></h1>

            <h3>Frontend Developer</h3>

            <p>
                Passionate about creating beautiful, responsive
                and user-friendly websites using HTML and CSS.
            </p>

            <div class="hero-buttons">
                <a href="#projects" class="btn">View Projects</a>
                <a href="#contact" class="btn-outline">Contact Me</a>
            </div>

            <div class="social-icons">
                <a href="#"><i class="fab fa-github"></i></a>
                <a href="#"><i class="fab fa-linkedin"></i></a>
                <a href="#"><i class="fab fa-instagram"></i></a>
                <a href="#"><i class="fab fa-twitter"></i></a>
            </div>
        </div>
    </section>

    <section id="about">
        <h2 class="section-title">About Me</h2>

        <div class="card">
            <p>
                I am a BTech CSE student and aspiring Frontend Developer.
                I enjoy building clean, modern and responsive websites.
                Iam passionate about learning new technologies and improving my skills in HTML, CSS, and JavaScript.
                I enjoy learning new technologies and improving my skills in HTML, CSS,.
                My goal is to create amazing user experiences and contribute to the web development community.

            </p>
        </div>
    </section>

    <section id="skills">
        <h2 class="section-title">Skills</h2>

        <div class="skill-container">

            <div class="skill-card">
                <i class="fab fa-html5"></i>
                <h3>HTML5</h3>
            </div>

            <div class="skill-card">
                <i class="fab fa-css3-alt"></i>
                <h3>CSS3</h3>
            </div>

            <div class="skill-card">
                <i class="fab fa-git-alt"></i>
                <h3>Git</h3>
            </div>

            <div class="skill-card">
                <i class="fab fa-github"></i>
                <h3>GitHub</h3>
            </div>

        </div>
    </section>

    <section id="projects">
        <h2 class="section-title">Projects</h2>

        <div class="project-container">

            <div class="project-card">
                <i class="fas fa-calculator"></i>
                <h3>Calculator</h3>
                <p>Responsive calculator using HTML & CSS.</p>
            </div>

            <div class="project-card">
                <i class="fas fa-user"></i>
                <h3>Portfolio Website</h3>
                <p>Modern personal portfolio website.</p>
            </div>

            <div class="project-card">
                <i class="fas fa-laptop-code"></i>
                <h3>Landing Page</h3>
                <p>Beautiful responsive landing page.</p>
            </div>

        </div>
    </section>

    <section id="contact">

    <h2 class="section-title">Contact Me</h2>

    <form class="contact-form">

        <input type="text" placeholder="Enter Your Name" required>

        <input type="email" placeholder="Enter Your Email" required>

        <input type="text" placeholder="Subject">

        <textarea rows="5" placeholder="Your Message"></textarea>

        <button type="submit">Send Message</button>

    </form>

</section>

        <div class="card contact-card">
            <p><i class="fas fa-envelope"></i> yourmail@gmail.com</p>
            <p><i class="fab fa-github"></i> github.com/yourusername</p>
            <p><i class="fab fa-linkedin"></i> linkedin.com/in/yourusername</p>
        </div>
    </section>

    <footer>
        <p>© 2026 Anjali Patial | Portfolio</p>
    </footer>

</body>
</html>